# ---- Microsoft Entra (BACKEND app — app-only Graph access) ----
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_SECRET=put-the-backend-app-secret-here

# ---- SharePoint Embedded ----
# ContainerTypeId GUID from your IT team (owning app must be the backend app above)
CONTAINER_TYPE_ID=00000000-0000-0000-0000-000000000000
# Leave CONTAINER_ID blank; the create-container script fills it in for you.
CONTAINER_ID=
CONTAINER_DISPLAY_NAME=Vessel DMS Documents

# ---- PostgreSQL ----
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/vessel_dms

# ---- Optional behaviour ----
MONTH_FOLDER_FORMAT=%B %Y
